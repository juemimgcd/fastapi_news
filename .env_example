# .env_example

# ========== App ==========
APP_NAME=fastapi_news
ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_PREFIX=/api
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:5173

# ========== Database ==========
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/backend

# ========== Redis ==========
REDIS_URL=redis://HOST:6379/0
